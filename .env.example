# =============================================================================
# Data Ruler - Environment Configuration
# =============================================================================
# Copy to .env and fill in your values

# --- Authentication ---
NEXTAUTH_SECRET=your-secret-key-here-change-in-production
NEXTAUTH_URL=http://localhost:3000

# --- AI Service ---
AI_SERVICE_URL=http://localhost:8000

# =============================================================================
# Ollama Cloud — AI Model Provider
# =============================================================================
# Get your API key from your Ollama Cloud instance
# Model is locked to gemini-3-flash-preview (not configurable)
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1

# --- LLM Settings ---
LLM_TIMEOUT=120

# --- Storage Paths ---
DATABASE_PATH=./data/databases
UPLOAD_PATH=./data/uploads
VECTOR_PATH=./data/vectors
THUMBNAIL_PATH=./data/thumbnails
TRANSCRIPTION_PATH=./data/transcriptions
EXPORT_PATH=./data/exports

# --- Production (Oracle Cloud) ---
# Set your domain for HTTPS (used by Caddy in docker-compose.prod.yml)
# Free subdomain available at: https://www.duckdns.org
DOMAIN=your-domain.com
