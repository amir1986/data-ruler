# =============================================================================
# Data Ruler - Environment Configuration
# =============================================================================
# Copy to .env and fill in your API keys

# --- Authentication ---
NEXTAUTH_SECRET=your-secret-key-here-change-in-production
NEXTAUTH_URL=http://localhost:3000

# --- AI Service ---
AI_SERVICE_URL=http://localhost:8000

# =============================================================================
# Cloud LLM Providers (FREE TIERS - configure at least one)
# =============================================================================

# Option 1: Groq (RECOMMENDED - fastest free tier)
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_CODE_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# Option 2: OpenRouter (many free models available)
# Get your free API key at: https://openrouter.ai/keys
OPENROUTER_API_KEY=
OPENROUTER_CHAT_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_CODE_MODEL=meta-llama/llama-3.3-70b-instruct:free
OPENROUTER_FAST_MODEL=meta-llama/llama-3.1-8b-instruct:free

# Option 3: HuggingFace Inference API (free tier)
# Get your free token at: https://huggingface.co/settings/tokens
HF_API_TOKEN=
HF_CHAT_MODEL=meta-llama/Llama-3.1-8B-Instruct
HF_EMBED_MODEL=sentence-transformers/all-MiniLM-L6-v2

# --- LLM Settings ---
LLM_TIMEOUT=120

# --- Storage Paths ---
DATABASE_PATH=./data/databases
UPLOAD_PATH=./data/uploads
VECTOR_PATH=./data/vectors
THUMBNAIL_PATH=./data/thumbnails
TRANSCRIPTION_PATH=./data/transcriptions
EXPORT_PATH=./data/exports
