# =============================================================================
# Data Ruler - Environment Configuration
# =============================================================================
# Copy to .env and fill in your API keys

# --- Authentication ---
NEXTAUTH_SECRET=your-secret-key-here-change-in-production
NEXTAUTH_URL=http://localhost:3000

# --- AI Service ---
AI_SERVICE_URL=http://localhost:8000

# =============================================================================
# Cloud LLM Providers (configure at least one)
# =============================================================================

# Option 1: Groq (RECOMMENDED - fastest free tier)
# Get your free API key at: https://console.groq.com/keys
GROQ_API_KEY=
GROQ_CHAT_MODEL=llama-3.3-70b-versatile
GROQ_CODE_MODEL=llama-3.3-70b-versatile
GROQ_FAST_MODEL=llama-3.1-8b-instant

# Option 2: Ollama Cloud (remote Ollama instance with API key)
# Use your Ollama cloud API key and endpoint
# Model is locked to gemini-3-flash-preview (not configurable)
OLLAMA_CLOUD_API_KEY=
OLLAMA_CLOUD_BASE_URL=https://ollama.com/v1

# --- LLM Settings ---
LLM_TIMEOUT=120

# --- Storage Paths ---
DATABASE_PATH=./data/databases
UPLOAD_PATH=./data/uploads
VECTOR_PATH=./data/vectors
THUMBNAIL_PATH=./data/thumbnails
TRANSCRIPTION_PATH=./data/transcriptions
EXPORT_PATH=./data/exports

# --- Production (Oracle Cloud) ---
DOMAIN=your-domain.com
