FROM node:20-alpine AS base

# Install dependencies
FROM base AS deps
WORKDIR /app
RUN apk add --no-cache python3 make g++
COPY apps/web/package.json apps/web/package-lock.json ./
RUN npm install --legacy-peer-deps --network-timeout=120000

# Build
FROM base AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY apps/web/ .
ENV NEXT_TELEMETRY_DISABLED=1
ARG BUILD_VERSION=dev
ENV NEXT_PUBLIC_BUILD_VERSION=$BUILD_VERSION
RUN npm run build

# Production
FROM base AS runner
WORKDIR /app
ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

RUN addgroup --system --gid 1001 nodejs && \
    adduser --system --uid 1001 nextjs

COPY --from=builder /app/public ./public
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static

# Native better-sqlite3 binary
COPY --from=deps --chown=nextjs:nodejs /app/node_modules/better-sqlite3 ./node_modules/better-sqlite3
COPY --from=deps --chown=nextjs:nodejs /app/node_modules/bindings ./node_modules/bindings
COPY --from=deps --chown=nextjs:nodejs /app/node_modules/file-uri-to-path ./node_modules/file-uri-to-path
COPY --from=deps --chown=nextjs:nodejs /app/node_modules/prebuild-install ./node_modules/prebuild-install

# Entrypoint
RUN printf '#!/bin/sh\nmkdir -p /data/databases /data/uploads\nchown -R nextjs:nodejs /data 2>/dev/null || true\nexec su-exec nextjs node server.js\n' > /app/entrypoint.sh && \
    chmod +x /app/entrypoint.sh

RUN apk add --no-cache su-exec

EXPOSE 3000

CMD ["/app/entrypoint.sh"]
